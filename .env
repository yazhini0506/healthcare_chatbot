# ============================================================
# Healthcare Lead Generation Agent - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.

# --- Google Gemini API ---
GEMINI_API_KEY=your_gemini_API_key
# --- Email Configuration (Gmail SMTP recommended) ---
EMAIL_SENDER=your_mail_id
EMAIL_PASSWORD=your_mail_app_password
EMAIL_SALES_TEAM=sales_team_mail_id
# --- SMTP Settings (defaults work for Gmail) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- App Settings ---
SECRET_KEY=set_password
DEBUG=True
